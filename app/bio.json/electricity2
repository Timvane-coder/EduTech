getCircuitSymbol(component) {
    const symbols = {
        cell: "—|+—",
        battery: "—||+—",
        resistor: "—▭—",
        variable_resistor: "—▭→—",
        lamp: "—⊗—",
        ammeter: "—(A)—",
        voltmeter: "—(V)— (parallel)",
        switch: "—/—",
        diode: "—▷|—",
        led: "—▷|—→",
        thermistor: "—▭t—",
        ldr: "—▭☼—",
        capacitor: "—||—",
        electrolytic_capacitor: "—|+|—"
    };

    return symbols[component] || "Component not found";
}

getSafetyReminder(context) {
    const safetyReminders = {
        high_voltage: "CAUTION: High voltage. Ensure proper insulation and earthing.",
        capacitor: "CAUTION: Capacitors can store charge. Always discharge before handling.",
        mains: "DANGER: Mains voltage (230V AC). Only qualified electricians should work on mains circuits.",
        short_circuit: "WARNING: Never short-circuit a cell or battery — can overheat and cause fire.",
        polarity: "CAUTION: Electrolytic capacitors are polarised. Reverse connection will damage them.",
        current_rating: "Check current rating of wires, fuses, and components before connecting."
    };

    return safetyReminders[context] || "Follow standard electrical safety procedures.";
}

