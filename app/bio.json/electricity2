adaptElectricityLanguage(text, level) {
    if (!text) return '';

    const adaptations = {
        basic: {
            replacements: {
                'potential difference': 'voltage',
                'electromotive force': 'EMF (battery voltage)',
                'terminal voltage': 'voltage across terminals',
                'internal resistance': 'resistance inside the battery',
                'resistivity': 'resistance property of material',
                'capacitance': 'ability to store charge',
                'time constant': 'charging/discharging time',
                'drift velocity': 'average electron speed',
                'charge carrier density': 'number of free electrons'
            }
        },
        intermediate: {
            replacements: {
                'potential difference': 'p.d. (voltage)',
                'electromotive force': 'EMF (ε)',
                'terminal voltage': 'V_terminal',
                'resistivity': 'ρ (material property)'
            }
        },
        advanced: {
            replacements: {
                'potential difference': 'p.d. V = W/Q',
                'current': 'I = dQ/dt = nAve',
                'resistance': 'R = ρL/A',
                'power': 'P = IV = I²R = V²/R',
                'capacitance': 'C = Q/V = ε₀εᵣA/d'
            }
        }
    };

    const levelAdaptation = adaptations[level] || adaptations.intermediate;
    let adaptedText = text;

    for (const [term, replacement] of Object.entries(levelAdaptation.replacements)) {
        const regex = new RegExp(`\\b${term}\\b`, 'gi');
        adaptedText = adaptedText.replace(regex, replacement);
    }

    return adaptedText;
}

