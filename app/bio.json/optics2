// Additional optics-specific helper methods

identifyOpticalInstrument(description) {
    const instruments = {
        magnifying_glass: /magnif.*glass|simple.*microscope|hand.*lens/i,
        compound_microscope: /compound.*microscope|microscope.*two.*lens/i,
        telescope: /telescope|refracting.*telescope|astronomical/i,
        camera: /camera|photograph/i,
        eye: /human.*eye|vision|eyesight|retina/i,
        spectacles: /spectacles|glasses|contact.*lens|vision.*correction/i,
        spectrometer: /spectrometer|spectroscope|grating.*instrument/i,
        periscope: /periscope|submarine/i,
        binoculars: /binoculars|prism.*binoculars/i,
        projector: /projector|cinema.*projector/i
    };

    for (const [instrument, pattern] of Object.entries(instruments)) {
        if (pattern.test(description)) {
            return instrument;
        }
    }

    return null;
}

calculateWavelengthFromFringes(fringeSpacing, slitSeparation, screenDistance) {
    // w = λD/d  →  λ = wd/D
    return (fringeSpacing * slitSeparation) / screenDistance;
}

calculateFringeSpacing(wavelength, slitSeparation, screenDistance) {
    // w = λD/d
    return (wavelength * screenDistance) / slitSeparation;
}

calculateGratingAngle(wavelength, gratingSpacing, order) {
    // d·sin(θ) = nλ  →  sin(θ) = nλ/d
    const sinTheta = (order * wavelength) / gratingSpacing;
    if (sinTheta > 1) {
        return null; // Order not visible
    }
    return Math.asin(sinTheta);
}

calculateMaximumGratingOrder(wavelength, gratingSpacing) {
    // n_max = floor(d/λ)
    return Math.floor(gratingSpacing / wavelength);
}

calculatePhotonEnergy(wavelength) {
    const h = 6.63e-34; // J·s
    const c = 3.0e8;    // m/s
    // E = hc/λ
    return (h * c) / wavelength;
}

calculatePhotonFrequency(wavelength) {
    const c = 3.0e8; // m/s
    // f = c/λ
    return c / wavelength;
}

identifyEMRegion(wavelength) {
    // wavelength in metres
    if (wavelength > 0.1) return { region: 'Radio Waves', hazard: 'none' };
    if (wavelength > 1e-3) return { region: 'Microwaves', hazard: 'heating at high power' };
    if (wavelength > 700e-9) return { region: 'Infrared', hazard: 'burns, eye damage' };
    if (wavelength > 400e-9) return { region: 'Visible Light', hazard: 'retinal damage if very bright' };
    if (wavelength > 10e-9) return { region: 'Ultraviolet', hazard: 'skin cancer, cataracts' };
    if (wavelength > 0.01e-9) return { region: 'X-rays', hazard: 'ionising radiation, cancer' };
    return { region: 'Gamma Rays', hazard: 'highly ionising, severe radiation damage' };
}

convertWavelengthToColour(wavelength_nm) {
    if (wavelength_nm < 380) return 'Ultraviolet (invisible)';
    if (wavelength_nm < 450) return 'Violet';
    if (wavelength_nm < 495) return 'Blue';
    if (wavelength_nm < 570) return 'Green';
    if (wavelength_nm < 590) return 'Yellow';
    if (wavelength_nm < 620) return 'Orange';
    if (wavelength_nm < 700) return 'Red';
    return 'Infrared (invisible)';
}

suggestOpticsExperiment(topic) {
    const experiments = {
        reflection: ['laws_of_reflection'],
        refraction: ['snells_law_experiment'],
        lenses: ['focal_length_lens'],
        wave_optics: ['youngs_double_slit', 'diffraction_grating_spectra'],
        dispersion_spectra: ['diffraction_grating_spectra']
    };

    const experimentIds = experiments[topic] || [];
    return experimentIds.map(id => ({
        id,
        name: this.opticsExperiments[id]?.name,
        category: this.opticsExperiments[id]?.category
    }));
}
