adaptOpticsLanguage(text, level) {
    if (!text) return '';

    const adaptations = {
        basic: {
            replacements: {
                'refractive index': 'light-slowing number',
                'total internal reflection': 'light trapped and bouncing inside',
                'converging lens': 'lens that brings light together',
                'diverging lens': 'lens that spreads light apart',
                'focal length': 'focus distance',
                'constructive interference': 'waves adding up',
                'destructive interference': 'waves cancelling out',
                'diffraction': 'wave spreading',
                'coherent': 'synchronized waves',
                'monochromatic': 'single colour'
            }
        },
        intermediate: {
            replacements: {
                'refractive index': 'refractive index (n = c/v)',
                'total internal reflection': 'TIR (when θᵢ > θ_c)',
                'focal length': 'focal length f'
            }
        },
        advanced: {
            replacements: {
                'refractive index': 'refractive index n = c/v = sin(θᵢ)/sin(θᵣ)',
                'total internal reflection': 'TIR (sin(θ_c) = n₂/n₁; θᵢ > θ_c)',
                'focal length': 'focal length f; optical power P = 1/f',
                'interference': 'interference (Δ = nλ constructive; Δ = (n+½)λ destructive)',
                'diffraction grating': 'diffraction grating (d·sin(θ) = nλ)'
            }
        }
    };

    const levelAdaptation = adaptations[level] || adaptations.intermediate;
    let adaptedText = text;

    for (const [term, replacement] of Object.entries(levelAdaptation.replacements)) {
        const regex = new RegExp(`\\b${term}\\b`, 'gi');
        adaptedText = adaptedText.replace(regex, replacement);
    }

    return adaptedText;
}

