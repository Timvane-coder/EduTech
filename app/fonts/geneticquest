        type: 'mendelian_genetics',
        context: { difficulty: 'beginner', topic: 'Mendelian Genetics', focus: 'dominance' },
        subparts: [
            'Law of Dominance:',
            '  - When two different alleles present, one masks the other',
            '  - Dominant allele expressed in heterozygote',
            '  - Recessive allele hidden in heterozygote',
            '',
            'Pea Plant Height Example:',
            '  - T (tall) is dominant',
            '  - t (short) is recessive',
            '',
            'Genotypes and Phenotypes:',
            '  - TT (homozygous dominant) → Tall',
            '  - Tt (heterozygous) → Tall (T masks t)',
            '  - tt (homozygous recessive) → Short',
            '',
            'Key Point: Tt looks identical to TT because T is dominant'
        ],
        helper: 'Dominant allele (capital) masks recessive (lowercase) in heterozygote',
        solution: 'Dominant allele expressed when present; recessive only expressed when homozygous',
        realWorldContext: 'Many human traits follow this pattern (widow\'s peak, dimples)'
    });

    // Problem 2: Law of Segregation
    relatedProblems.push({
        difficulty: 'similar',
        scenario: 'Law of Segregation',
        problem: 'Describe Mendel\'s Law of Segregation and explain how alleles separate during gamete formation',
        parameters: {
