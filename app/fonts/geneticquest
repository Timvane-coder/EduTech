            '  - Offspring get new combination',
            '',
            'Aa × Aa cross:',
            '  - Parent gametes: A, a (from each)',
            '  - Offspring: 25% AA, 50% Aa, 25% aa',
            '  - Phenotypic ratio: 3:1 (dominant:recessive)'
        ],
        helper: 'Each gamete gets one allele from each pair (like dealing cards)',
        solution: 'Allele pairs separate during meiosis; each gamete receives one allele per gene',
        realWorldContext: 'This ensures genetic variation in offspring'
    });

    // Problem 3: Independent Assortment
    relatedProblems.push({
        difficulty: 'harder',
        scenario: 'Law of Independent Assortment',
        problem: 'Explain Mendel\'s Law of Independent Assortment using a dihybrid cross example',
        parameters: {
            specificItems: ['Law of Independent Assortment'],
            type: 'law',
            limit: 1
        },
        type: 'mendelian_genetics',
        context: { difficulty: 'intermediate', topic: 'Mendelian Genetics', focus: 'independent assortment' },
        subparts: [
            'Law of Independent Assortment:',
            '  - Genes for different traits segregate independently',
            '  - Inheritance of one trait doesn\'t affect another',
            '  - Only true for genes on different chromosomes (not linked)',
            '',
            'Dihybrid Cross Example (TtYy × TtYy):',
            '  - T/t = height (Tall/short)',
            '  - Y/y = seed color (Yellow/green)',
            '',
            'Parent TtYy produces 4 gamete types:',
            '  - TY (25%)',
            '  - Ty (25%)',
            '  - tY (25%)',
            '  - ty (25%)',
            '',
            'F2 Phenotypic Ratio: 9:3:3:1',
            '  - 9 Tall Yellow (T_Y_)',
            '  - 3 Tall green (T_yy)',
            '  - 3 short Yellow (ttY_)',
            '  - 1 short green (ttyy)',
            '',
            'Why 9:3:3:1?',
            '  - Height: 3:1 ratio (Tall:short)',
            '  - Color: 3:1 ratio (Yellow:green)',
            '  - Independent: 3:1 × 3:1 = 9:3:3:1',
            '',
            'Exception: Linked genes (same chromosome) don\'t assort independently'
        ],
        helper: 'Different traits sorted independently (height doesn\'t affect color)',
        solution: 'Genes on different chromosomes assort independently; produces 9:3:3:1 ratio in dihybrid cross',
        realWorldContext: 'Allows unlimited combinations of parental traits in offspring'
    });

    // Problem 4: Genotype vs Phenotype
    relatedProblems.push({
