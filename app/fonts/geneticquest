            '',
            'CASE 1: Unknown is AA',
            '',
            'Cross: AA × aa',
            '',
            'Gametes:',
            '  AA parent: All A',
            '  aa parent: All a',
            '',
            'Punnett Square:',
            '       a    a',
            '   ┌─────────┐',
            ' A │ Aa | Aa │',
            '   ├─────────┤',
            ' A │ Aa | Aa │',
            '   └─────────┘',
            '',
            'Result: 100% Aa (all dominant phenotype)',
            'Conclusion: Unknown was AA',
            '',
            'CASE 2: Unknown is Aa',
            '',
            'Cross: Aa × aa',
            '',
            'Gametes:',
            '  Aa parent: A and a',
            '  aa parent: All a',
            '',
            'Punnett Square:',
            '       a    a',
            '   ┌─────────┐',
            ' A │ Aa | Aa │',
            '   ├─────────┤',
            ' a │ aa | aa │',
            '   └─────────┘',
            '',
            'Result: 50% Aa, 50% aa',
            'Phenotypic ratio: 1:1 (dominant:recessive)',
            'Conclusion: Unknown was Aa',
            '',
            'Interpretation:',
            '  If any recessive offspring → Unknown was heterozygous',
            '  If all dominant offspring → Unknown was homozygous dominant'
