        problem: 'Distinguish between genotype and phenotype, providing clear examples',
        parameters: {
            specificItems: ['genotype', 'phenotype'],
            limit: 2
        },
        type: 'mendelian_genetics',
        context: { difficulty: 'beginner', topic: 'Mendelian Genetics', focus: 'terminology' },
        subparts: [
            'GENOTYPE:',
            '  Definition: Genetic makeup (alleles present)',
            '  - Written with letters',
            '  - Examples: AA, Aa, aa',
            '  - Cannot see by looking',
            '  - Determines potential',
            '',
            'PHENOTYPE:',
            '  Definition: Physical appearance (traits expressed)',
            '  - What you can observe',
            '  - Examples: Tall, short, purple flowers',
            '  - Result of genotype + environment',
            '  - What you see',
            '',
            'Relationship:',
            '  Genotype → Phenotype',
            '  (Genetic code → Observable trait)',
            '',
            'Examples:',
            '  Height in pea plants:',
            '    Genotype TT → Phenotype Tall',
            '    Genotype Tt → Phenotype Tall',
            '    Genotype tt → Phenotype Short',
            '',
            '  Note: TT and Tt have different genotypes',
            '        but SAME phenotype (both tall)',
            '',
            'Key Insight:',
            '  - Cannot always determine genotype from phenotype',
            '  - Dominant phenotype could be AA or Aa',
            '  - Need test cross to determine'
        ],
        helper: 'Genotype = genes you have; Phenotype = traits you show',
        solution: 'Genotype is genetic makeup (AA, Aa, aa); Phenotype is observable trait (tall, short)',
        realWorldContext: 'Identical twins have same genotype but can have slightly different phenotypes'
    });

    // Problem 5: Test Cross
    relatedProblems.push({
        difficulty: 'similar',
        scenario: 'Test Cross to Determine Unknown Genotype',
        problem: 'Explain how a test cross is used to determine if a dominant phenotype is homozygous or heterozygous',
        parameters: {
            specificItems: ['Test Cross'],
            type: 'cross',
            limit: 1
        },
        type: 'mendelian_genetics',
        context: { difficulty: 'intermediate', topic: 'Mendelian Genetics', focus: 'test cross' },
        subparts: [
            'TEST CROSS:',
            '  Purpose: Determine unknown genotype',
            '  Method: Cross with homozygous recessive (aa)',
            '',
            'Problem: Tall pea plant (T_)',
            '  - Could be TT or Tt',
            '  - Both look identical (tall)',
            '  - How to determine which?',
            '',
            'Solution: Test Cross',
            '  Cross unknown (T?) with short plant (tt)',
            '',
            'SCENARIO 1: Unknown is TT',
            '  Cross: TT × tt',
            '  Offspring: All Tt (100% tall)',
            '  Conclusion: Unknown was TT',
            '',
            'SCENARIO 2: Unknown is Tt',
            '  Cross: Tt × tt',
            '  Offspring: 50% Tt (tall), 50% tt (short)',
            '  Ratio: 1:1 (Tall:short)',
            '  Conclusion: Unknown was Tt',
            '',
            'Why Use Homozygous Recessive?',
            '  - Only contributes recessive allele (t)',
            '  - Offspring phenotype reveals unknown\'s alleles',
            '  - If any short offspring appear → unknown was Tt',
            '  - If all tall → unknown was TT',
            '',
            'General Rule:',
            '  A? × aa',
            '  - All dominant phenotype → A? is AA',
            '  - Some recessive phenotype → A? is Aa'
        ],
        helper: 'Cross with recessive (aa) to reveal hidden alleles',
        solution: 'Test cross with homozygous recessive; offspring ratio reveals unknown genotype',
        realWorldContext: 'Breeders use test crosses to identify pure-breeding individuals'
    });

    return relatedProblems;
}

