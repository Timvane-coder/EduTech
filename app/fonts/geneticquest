            '  Top-right: Aa',
            '  Bottom-left: Aa',
            '  Bottom-right: aa',
            '',
            'Step 4: Count Genotypes',
            '  1 AA : 2 Aa : 1 aa',
            '  Genotypic ratio = 1:2:1',
            '',
            'Step 5: Determine Phenotypes (assuming complete dominance)',
            '  AA → Dominant phenotype',
            '  Aa → Dominant phenotype',
            '  aa → Recessive phenotype',
            '  3 Dominant : 1 Recessive',
            '  Phenotypic ratio = 3:1',
            '',
            'Probabilities:',
            '  AA: 25% (1/4)',
            '  Aa: 50% (2/4)',
