        helper: 'List gametes, make 2×2 grid, combine alleles from row and column',
        solution: 'Genotypic ratio 1:2:1 (AA:Aa:aa); Phenotypic ratio 3:1 (dominant:recessive)',
        realWorldContext: 'Predicts probability of genetic diseases in children'
    });

    // Problem 2: Dihybrid Cross
    relatedProblems.push({
        difficulty: 'harder',
        scenario: 'Dihybrid Punnett Square',
        problem: 'Construct a dihybrid Punnett square for AaBb × AaBb and interpret the 9:3:3:1 ratio',
        parameters: {
            specificItems: ['dihybrid'],
            type: 'dihybridCross',
            genotype: 'AaBb',
            limit: 1
        },
        type: 'punnett_squares',
        context: { difficulty: 'intermediate', topic: 'Punnett Squares', focus: 'dihybrid' },
        subparts: [
            'Dihybrid Cross: AaBb × AaBb',
            '  (Two traits: A/a and B/b)',
            '',
            'Step 1: Determine Gametes (use FOIL)',
            '  Parent AaBb can produce:',
            '  - AB (First: A and B)',
            '  - Ab (Outer: A and b)',
            '  - aB (Inner: a and B)',
            '  - ab (Last: a and b)',
            '  Each gamete type: 25% probability',
            '',
            'Step 2: Set Up Punnett Square (4×4)',
            '  16 boxes total',
            '  Each parent contributes one of 4 gamete types',
            '',
            'Step 3: Fill in all 16 combinations',
            '  (Showing abbreviated - too large for full display)',
            '',
            'Step 4: Count Phenotypes',
            '  Assuming complete dominance for both genes:',
            '',
            '  A_B_ (Dominant for both): 9/16',
            '  A_bb (Dom A, rec b): 3/16',
            '  aaB_ (rec a, Dom B): 3/16',
            '  aabb (rec both): 1/16',
            '',
            'Phenotypic Ratio: 9:3:3:1',
            '',
            'Example (Height and Color):',
            '  9 Tall Yellow',
            '  3 Tall green',
            '  3 short Yellow',
            '  1 short green',
            '',
            'Why 9:3:3:1?',
            '  Height ratio: 3 Tall : 1 short',
            '  Color ratio: 3 Yellow : 1 green',
            '  Combined: (3:1) × (3:1) = 9:3:3:1',
            '',
            'This ratio confirms:',
            '  - Independent assortment',
            '  - Two unlinked genes',
            '  - Complete dominance for both'
        ],
        helper: 'Use FOIL to find 4 gamete types, then make 4×4 grid (16 boxes)',
        solution: 'Dihybrid produces 9:3:3:1 phenotypic ratio when genes assort independently',
        realWorldContext: 'Used to predict multiple traits simultaneously in breeding programs'
