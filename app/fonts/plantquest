// ============== HELPER FUNCTION FOR GENERATING PROBLEM SECTIONS ==============

function generateProblemSections(workbook) {
    const sections = [];

    // Add detailed explanation section
    if (workbook.contentSteps && workbook.contentSteps.length > 0) {
        sections.push(
            new docx.Paragraph({
                text: 'Detailed Explanation:',
                heading: docx.HeadingLevel.HEADING_3,
                spacing: { before: 300, after: 200 }
            })
        );

        workbook.contentSteps.forEach(step => {
            if (typeof step === 'string') {
                sections.push(
                    new docx.Paragraph({
                        text: step,
                        spacing: { after: 100 }
                    })
                );
            }
        });
    }

    // Add key concepts section
    if (workbook.currentContent && workbook.currentContent.keyDefinitions) {
        sections.push(
            new docx.Paragraph({
                text: 'Key Concepts and Definitions:',
                heading: docx.HeadingLevel.HEADING_3,
                spacing: { before: 300, after: 200 }
            })
        );

        Object.entries(workbook.currentContent.keyDefinitions).forEach(([term, definition]) => {
            sections.push(
                new docx.Paragraph({
                    text: `${term}: ${definition}`,
                    spacing: { after: 100 },
                    bullet: { level: 0 }
                })
            );
        });
    }

    // Add main categories/components section
    if (workbook.currentContent) {
