        if (workbook.currentContent.majorHormones) {
            sections.push(
                new docx.Paragraph({
                    text: 'Plant Hormones:',
                    heading: docx.HeadingLevel.HEADING_3,
                    spacing: { before: 300, after: 200 }
                })
            );

            Object.entries(workbook.currentContent.majorHormones).forEach(([key, hormone]) => {
                sections.push(
                    new docx.Paragraph({
                        text: `${hormone.name} (${hormone.type})`,
