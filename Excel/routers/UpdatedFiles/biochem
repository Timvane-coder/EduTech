// Flat ordered list matching CLI menu order
const DIAGRAM_LIST = Object.entries(BIOCHEMICAL_DIAGRAMS).map(([key, def]) => ({
  key,
  ...def
}))

export default function InsertTab({ onAddVisualization, sessionId }) {
  // Navigation state — mirrors CLI: main → system → group → case
  const [view, setView] = useState('main')          // 'main' | 'system' | 'group' | 'gallery'
  const [selectedKey, setSelectedKey] = useState(null)
  const [selectedGroupIdx, setSelectedGroupIdx] = useState(null)

  // Gallery state
  const [galleryItems, setGalleryItems] = useState([])
  const [loadedImages, setLoadedImages] = useState({})
  const [imageErrors, setImageErrors] = useState({})
  const [isLoadingGallery, setIsLoadingGallery] = useState(false)
  const [selectedImage, setSelectedImage] = useState(null)
  const [viewType, setViewType] = useState('all')

  // Rendering feedback
  const [renderingCase, setRenderingCase] = useState(null)   // { desc } while in-flight
  const [lastResult, setLastResult] = useState(null)          // { ok, message }

  useEffect(() => {
    if (view === 'gallery') loadGalleryItems()
  }, [view, viewType])

  // ── Gallery helpers ────────────────────────────────────────────────────────

  const loadGalleryItems = async () => {
    if (!sessionId) return
    setIsLoadingGallery(true)
    try {
      const res = await fetch(`/api/workbook/visualizations/gallery?sessionId=${sessionId}&type=${viewType}`)
      if (!res.ok) { setGalleryItems([]); return }
      const data = await res.json()
      const items = data.items || []
      setGalleryItems(items)
      items.forEach(item => loadItemImage(item))
    } catch { setGalleryItems([]) }
    finally { setIsLoadingGallery(false) }
  }

  const loadItemImage = async (item) => {
    if (loadedImages[item.id] || imageErrors[item.id]) return
    try {
      const res = await fetch(`/api/workbook/visualizations/image?sessionId=${sessionId}&type=${item.type}&id=${item.id}`)
      if (res.ok) {
        const blob = await res.blob()
        setLoadedImages(prev => ({ ...prev, [item.id]: URL.createObjectURL(blob) }))
      } else {
        const err = await res.json()
        setImageErrors(prev => ({ ...prev, [item.id]: err.error || 'Failed' }))
      }
    } catch (e) {
      setImageErrors(prev => ({ ...prev, [item.id]: e.message }))
    }
  }

  useEffect(() => {
    return () => Object.values(loadedImages).forEach(u => u && URL.revokeObjectURL(u))
  }, [loadedImages])

  const handleDownloadImage = async (item) => {
    const url = loadedImages[item.id]
    if (!url) { alert('Image not loaded yet'); return }
    const a = document.createElement('a')
    a.href = url
    a.download = `${item.type}-${item.id}.png`
    a.click()
  }

  const handleDeleteImage = async (item) => {
    if (!confirm(`Delete "${item.title}"?`)) return
    try {
      const res = await fetch(`/api/workbook/visualizations/delete?sessionId=${sessionId}&type=${item.type}&id=${item.id}`, { method: 'DELETE' })
      if (res.ok) {
        setGalleryItems(prev => prev.filter(i => i.id !== item.id))
        setLoadedImages(prev => { const n = { ...prev }; URL.revokeObjectURL(n[item.id]); delete n[item.id]; return n })
      } else {
        const e = await res.json()
        alert(`❌ ${e.error}`)
      }
    } catch { alert('Delete failed') }
  }

  // ── Render a single case via the API ──────────────────────────────────────

  const handleRenderCase = async (diagramKey, tc) => {
    const def = BIOCHEMICAL_DIAGRAMS[diagramKey]
    setRenderingCase({ desc: tc.desc })
    setLastResult(null)
    try {
      const config = {
        key: diagramKey,
        title: tc.desc,
        options: {
          ...tc.options,
          width: tc.width || def.width,
          height: tc.height || def.height
        }
      }
      await onAddVisualization('biochemical', config)
      setLastResult({ ok: true, message: `✅ "${tc.desc}" rendered and saved` })
      // Reload gallery if open
      if (view === 'gallery') await loadGalleryItems()
    } catch (err) {
      setLastResult({ ok: false, message: `❌ Failed: ${err.message}` })
    } finally {
      setRenderingCase(null)
    }
  }

  // Render ALL cases in a group
  const handleRenderAllGroup = async (diagramKey, groupIdx) => {
    const def = BIOCHEMICAL_DIAGRAMS[diagramKey]
    const group = def.groups[groupIdx]
    setLastResult(null)
    let ok = 0, fail = 0
    for (const tc of group.cases) {
      setRenderingCase({ desc: tc.desc })
      try {
        const config = {
          key: diagramKey,
          title: tc.desc,
          options: { ...tc.options, width: tc.width || def.width, height: tc.height || def.height }
        }
        await onAddVisualization('biochemical', config)
        ok++
      } catch { fail++ }
    }
    setRenderingCase(null)
    setLastResult({ ok: fail === 0, message: `✅ ${ok} rendered${fail ? `, ❌ ${fail} failed` : ''}` })
  }

  // Render ALL groups for a system
  const handleRenderAllSystem = async (diagramKey) => {
    const def = BIOCHEMICAL_DIAGRAMS[diagramKey]
    setLastResult(null)
    let ok = 0, fail = 0
    for (let gi = 0; gi < def.groups.length; gi++) {
      for (const tc of def.groups[gi].cases) {
        setRenderingCase({ desc: tc.desc })
        try {
          const config = {
            key: diagramKey,
            title: tc.desc,
            options: { ...tc.options, width: tc.width || def.width, height: tc.height || def.height }
          }
          await onAddVisualization('biochemical', config)
          ok++
        } catch { fail++ }
      }
    }
    setRenderingCase(null)
    setLastResult({ ok: fail === 0, message: `✅ ${ok} rendered${fail ? `, ❌ ${fail} failed` : ''}` })
  }

  // ── Navigation helpers ─────────────────────────────────────────────────────

  const goMain = () => { setView('main'); setSelectedKey(null); setSelectedGroupIdx(null); setLastResult(null) }
  const goSystem = (key) => { setView('system'); setSelectedKey(key); setSelectedGroupIdx(null); setLastResult(null) }
  const goGroup = (groupIdx) => { setView('group'); setSelectedGroupIdx(groupIdx); setLastResult(null) }

  const selectedDef = selectedKey ? BIOCHEMICAL_DIAGRAMS[selectedKey] : null
  const selectedGroup = selectedDef && selectedGroupIdx !== null ? selectedDef.groups[selectedGroupIdx] : null

  // ── Breadcrumb ─────────────────────────────────────────────────────────────

  const renderBreadcrumb = () => {
    if (view === 'main' || view === 'gallery') return null
    return (
      <div className="breadcrumb">
        <button onClick={goMain}>Main Menu</button>
        {(view === 'system' || view === 'group') && selectedDef && (
          <><span>›</span>
            {view === 'group'
              ? <button onClick={() => goSystem(selectedKey)}>[{selectedDef.tag}] {selectedDef.label}</button>
              : <span className="current">[{selectedDef.tag}] {selectedDef.label}</span>
            }
          </>
        )}
        {view === 'group' && selectedGroup && (
          <><span>›</span><span className="current">{selectedGroup.name}</span></>
        )}
      </div>
    )
  }

  // ── Render feedback banner ─────────────────────────────────────────────────

  const renderFeedback = () => {
    if (renderingCase) return (
      <div className="feedback rendering">
        <div className="spinner-small"></div>
        <span>Rendering: {renderingCase.desc}</span>
      </div>
    )
    if (lastResult) return (
      <div className={`feedback ${lastResult.ok ? 'success' : 'error'}`}>
        {lastResult.message}
      </div>
    )
    return null
  }

  // ── View: MAIN MENU ────────────────────────────────────────────────────────

  const renderMain = () => (
    <div className="menu-view">
      <div className="banner">
        <div className="banner-top">BIOCHEMICAL DIAGRAMS — Interactive Suite</div>
        <div className="banner-sub">BiochemicalDiagramsRegistry  •  Node.js Canvas  •  PNG Output</div>
      </div>
      <h4 className="menu-title">Select a diagram system:</h4>
      <div className="menu-divider"></div>
      <div className="menu-list">
        {DIAGRAM_LIST.map((def, i) => (
          <button key={def.key} className="menu-item" onClick={() => goSystem(def.key)}>
            <span className="menu-num">{String(i + 1).padStart(2, ' ')}.</span>
            <span className="menu-tag">[{def.tag}]</span>
            <span className="menu-label">{def.label}</span>
          </button>
        ))}
        <button className="menu-item special" onClick={() => setView('gallery')}>
          <span className="menu-num">🖼</span>
          <span className="menu-tag">[GAL]</span>
          <span className="menu-label">View Image Gallery</span>
        </button>
      </div>
    </div>
  )

  // ── View: SYSTEM MENU ──────────────────────────────────────────────────────

  const renderSystem = () => {
    if (!selectedDef) return null
    return (
      <div className="menu-view">
        <div className="banner">
          <div className="banner-top">BIOCHEMICAL DIAGRAMS — Interactive Suite</div>
          <div className="banner-sub">BiochemicalDiagramsRegistry  •  Node.js Canvas  •  PNG Output</div>
        </div>
        <div className="system-title">[{selectedDef.tag}] {selectedDef.label}</div>
        <h4 className="menu-title">Select a group:</h4>
        <div className="menu-divider"></div>
        <div className="menu-list">
          {selectedDef.groups.map((group, i) => (
            <button key={i} className="menu-item" onClick={() => goGroup(i)}>
              <span className="menu-num">{i + 1}.</span>
              <span className="menu-label">{group.name}</span>
              <span className="menu-count">({group.cases.length} diagrams)</span>
            </button>
          ))}
          <button
            className="menu-item special"
            onClick={() => handleRenderAllSystem(selectedKey)}
            disabled={!!renderingCase}
          >
            <span className="menu-num">[*]</span>
            <span className="menu-label">Render ALL groups for {selectedDef.label}</span>
          </button>
          <button className="menu-item back" onClick={goMain}>
            <span className="menu-num">[&lt;]</span>
            <span className="menu-label">Back to main menu</span>
          </button>
        </div>
      </div>
    )
  }

  // ── View: GROUP MENU ───────────────────────────────────────────────────────

  const renderGroup = () => {
    if (!selectedDef || !selectedGroup) return null
    return (
      <div className="menu-view">
        <div className="banner">
          <div className="banner-top">BIOCHEMICAL DIAGRAMS — Interactive Suite</div>
          <div className="banner-sub">BiochemicalDiagramsRegistry  •  Node.js Canvas  •  PNG Output</div>
        </div>
        <div className="system-title">[{selectedDef.tag}] {selectedDef.label}  &gt;  {selectedGroup.name}</div>
        <h4 className="menu-title">Select a diagram to render:</h4>
        <div className="menu-divider"></div>
        <div className="menu-list">
          {selectedGroup.cases.map((tc, i) => (
            <button
              key={i}
              className={`menu-item case-item ${renderingCase?.desc === tc.desc ? 'rendering' : ''}`}
              onClick={() => handleRenderCase(selectedKey, tc)}
              disabled={!!renderingCase}
            >
              <span className="menu-num">{i + 1}.</span>
              <span className="menu-label">{tc.desc}</span>
              {renderingCase?.desc === tc.desc && <span className="spinner-tiny"></span>}
            </button>
          ))}
          <button
            className="menu-item special"
            onClick={() => handleRenderAllGroup(selectedKey, selectedGroupIdx)}
            disabled={!!renderingCase}
          >
            <span className="menu-num">[*]</span>
            <span className="menu-label">Render ALL cases in this group</span>
          </button>
          <button className="menu-item back" onClick={() => goSystem(selectedKey)}>
            <span className="menu-num">[&lt;]</span>
            <span className="menu-label">Back to group list</span>
          </button>
        </div>
      </div>
    )
  }

  // ── View: GALLERY ──────────────────────────────────────────────────────────

  const viewTypes = [
    { id: 'all', label: '🎨 All' },
    ...DIAGRAM_LIST.map(d => ({ id: d.key, label: `[${d.tag}] ${d.label}` }))
  ]

  const renderGallery = () => (
    <div className="gallery-view">
      <div className="gallery-header">
        <h4 className="section-title">🖼️ Image Gallery</h4>
        <button className="back-btn" onClick={goMain}>← Back to Main Menu</button>
      </div>
      <div className="view-filters">
        {viewTypes.map(t => (
          <button key={t.id} className={`filter-btn ${viewType === t.id ? 'active' : ''}`} onClick={() => setViewType(t.id)}>
            {t.label}
          </button>
        ))}
      </div>
      {isLoadingGallery ? (
        <div className="loading-state"><div className="spinner"></div><p>Loading images...</p></div>
      ) : galleryItems.length === 0 ? (
        <div className="empty-state">
          <div className="empty-icon">🎨</div>
          <h3>No Images Yet</h3>
          <p>Render diagrams from the main menu to see them here</p>
        </div>
      ) : (
        <div className="gallery-grid">
          {galleryItems.map(item => (
            <div key={item.id} className="gallery-card">
              <div className="gallery-image" onClick={() => setSelectedImage(item)}>
                {loadedImages[item.id]
                  ? <img src={loadedImages[item.id]} alt={item.title} />
                  : imageErrors[item.id]
                    ? <div className="error-placeholder"><span>⚠️</span><p>Image not available</p></div>
                    : <div className="loading-placeholder"><div className="spinner-small"></div><p>Loading...</p></div>
                }
                <div className="gallery-overlay"><span>🔍</span></div>
              </div>
              <div className="gallery-info">
                <div className="gallery-header-info">
                  <h4 className="gallery-title">{item.title}</h4>
                  <span className="gallery-type-badge">{item.type}</span>
                </div>
                {item.category && <div className="gallery-category">{item.category}</div>}
                <div className="gallery-meta">
                  <span>{new Date(item.createdAt).toLocaleDateString()}</span>
                  <span>{item.size || 'N/A'}</span>
                </div>
                <div className="gallery-actions">
                  <button className="gallery-action-btn" onClick={() => handleDownloadImage(item)} title="Download">💾</button>
                  <button className="gallery-action-btn" onClick={() => setSelectedImage(item)} title="View">🔍</button>
                  <button className="gallery-action-btn delete" onClick={() => handleDeleteImage(item)} title="Delete">🗑️</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  )

  // ── Root render ────────────────────────────────────────────────────────────

  return (
    <div className="insert-tab-wrapper">
      <div className="scrollable-content">
        <div className="tab-header">
          <h3>🧬 Biochemical Diagram Suite</h3>
          <p className="subtitle">Step-by-step anatomical, cellular, and biochemical diagrams</p>
        </div>

        {renderBreadcrumb()}
        {renderFeedback()}

        {view === 'main' && renderMain()}
        {view === 'system' && renderSystem()}
        {view === 'group' && renderGroup()}
        {view === 'gallery' && renderGallery()}
      </div>

      {/* Lightbox */}
      {selectedImage && (
        <div className="lightbox" onClick={() => setSelectedImage(null)}>
          <div className="lightbox-content" onClick={e => e.stopPropagation()}>
            <button className="lightbox-close" onClick={() => setSelectedImage(null)}>×</button>
            <div className="lightbox-header">
              <h3>{selectedImage.title}</h3>
              <div className="lightbox-meta">
                <span>{selectedImage.type}</span>
                {selectedImage.category && <span>{selectedImage.category}</span>}
              </div>
